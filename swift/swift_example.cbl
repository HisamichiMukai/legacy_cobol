IDENTIFICATION DIVISION.
PROGRAM-ID. SWIFTPAYMENTBICDB2.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT SWIFT-BIC-FILE ASSIGN TO 'SWIFTBIC.TXT'
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-FILE-STATUS.

DATA DIVISION.
FILE SECTION.
FD SWIFT-BIC-FILE.
01 SWIFT-BIC-RECORD.
   05 SWIFT-CODE PIC X(11).
   05 FILLER PIC X(01).
   05 PAYMENT-AMOUNT PIC 9(05)V99.
   05 FILLER PIC X(01).
   05 PAYMENT-CURRENCY PIC X(03).
   05 FILLER PIC X(01).
   05 PAYMENT-DATE PIC 9(08).
   05 FILLER PIC X(01).
   05 BIC-CODE PIC X(11).

WORKING-STORAGE SECTION.
01 END-OF-FILE-SWITCH PIC X VALUE 'N'.
01 WS-FILE-STATUS PIC 99.
01 ERROR-MESSAGE PIC X(50).

EXEC SQL INCLUDE SQLCA END-EXEC.

PROCEDURE DIVISION.
    PERFORM INIT
    PERFORM MAIN
    PERFORM CLEANUP
    STOP RUN.

INIT.
    OPEN INPUT SWIFT-BIC-FILE.

MAIN.
    PERFORM UNTIL END-OF-FILE-SWITCH = 'Y'
        READ SWIFT-BIC-FILE
            AT END MOVE 'Y' TO END-OF-FILE-SWITCH
        END-READ
        PERFORM VALIDATE-SWIFT-PAYMENT
        IF SQLCODE = ZERO
            EXEC SQL
                INSERT INTO SWIFT_BIC_TABLE (SWIFT_CODE, PAYMENT_AMOUNT, PAYMENT_CURRENCY, PAYMENT_DATE, BIC_CODE)
                VALUES (:SWIFT-CODE, :PAYMENT-AMOUNT, :PAYMENT-CURRENCY, :PAYMENT-DATE, :BIC-CODE)
            END-EXEC
        ELSE
            DISPLAY 'SQL Error: ' SQLCODE
        END-IF
    END-PERFORM.

VALIDATE-SWIFT-PAYMENT.
    IF SWIFT-CODE = SPACES
        MOVE 'Invalid SWIFT Code' TO ERROR-MESSAGE
        DISPLAY ERROR-MESSAGE
    ELSE IF PAYMENT-AMOUNT = ZERO
        MOVE 'Invalid Payment Amount' TO ERROR-MESSAGE
        DISPLAY ERROR-MESSAGE
    ELSE IF PAYMENT-CURRENCY = SPACES
        MOVE 'Invalid Payment Currency' TO ERROR-MESSAGE
        DISPLAY ERROR-MESSAGE
    ELSE IF PAYMENT-DATE = ZERO
        MOVE 'Invalid Payment Date' TO ERROR-MESSAGE
        DISPLAY ERROR-MESSAGE
    ELSE IF BIC-CODE = SPACES
        MOVE 'Invalid BIC Code' TO ERROR-MESSAGE
        DISPLAY ERROR-MESSAGE
    END-IF.

CLEANUP.
    CLOSE SWIFT-BIC-FILE.
