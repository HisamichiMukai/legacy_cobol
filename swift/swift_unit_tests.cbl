IDENTIFICATION DIVISION.
PROGRAM-ID. SWIFTPAYMENTBICDB2-TEST.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT SWIFT-BIC-FILE ASSIGN TO 'SWIFTBIC.TXT'
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-FILE-STATUS.

DATA DIVISION.
FILE SECTION.
FD SWIFT-BIC-FILE.
01 SWIFT-BIC-RECORD.
   05 SWIFT-CODE PIC X(11).
   05 FILLER PIC X(01).
   05 PAYMENT-AMOUNT PIC 9(05)V99.
   05 FILLER PIC X(01).
   05 PAYMENT-CURRENCY PIC X(03).
   05 FILLER PIC X(01).
   05 PAYMENT-DATE PIC 9(08).
   05 FILLER PIC X(01).
   05 BIC-CODE PIC X(11).

WORKING-STORAGE SECTION.
01 END-OF-FILE-SWITCH PIC X VALUE 'N'.
01 WS-FILE-STATUS PIC 99.
01 TEST-RESULT PIC X(10).

EXEC SQL INCLUDE SQLCA END-EXEC.

PROCEDURE DIVISION.
    PERFORM RUN-TESTS
    STOP RUN.

RUN-TESTS.
    PERFORM TEST-OPEN-FILE
    PERFORM TEST-READ-FILE
    PERFORM TEST-VALIDATE-SWIFT-PAYMENT.

TEST-OPEN-FILE.
    OPEN INPUT SWIFT-BIC-FILE
    IF WS-FILE-STATUS = "00"
        MOVE "PASSED" TO TEST-RESULT
    ELSE
        MOVE "FAILED" TO TEST-RESULT
    END-IF
    DISPLAY "TEST-OPEN-FILE: " TEST-RESULT
    CLOSE SWIFT-BIC-FILE.

TEST-READ-FILE.
    OPEN INPUT SWIFT-BIC-FILE
    READ SWIFT-BIC-FILE
        AT END MOVE "FAILED" TO TEST-RESULT
    END-READ
    IF END-OF-FILE-SWITCH = "N"
        MOVE "PASSED" TO TEST-RESULT
    ELSE
        MOVE "FAILED" TO TEST-RESULT
    END-IF
    DISPLAY "TEST-READ-FILE: " TEST-RESULT
    CLOSE SWIFT-BIC-FILE.

TEST-VALIDATE-SWIFT-PAYMENT.
    MOVE "VALIDSWIFT" TO SWIFT-CODE
    MOVE 1000 TO PAYMENT-AMOUNT
    MOVE "USD" TO PAYMENT-CURRENCY
    MOVE 20230730 TO PAYMENT-DATE
    MOVE "VALIDBIC" TO BIC-CODE
    PERFORM VALIDATE-SWIFT-PAYMENT
    IF SQLCODE = 0
        MOVE "PASSED" TO TEST-RESULT
    ELSE
        MOVE "FAILED" TO TEST-RESULT
    END-IF
    DISPLAY "TEST-VALIDATE-SWIFT-PAYMENT: " TEST-RESULT.
